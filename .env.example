# ── Temperature calibration ───────────────────────────────────────────────────
# Known actual temperature in °F from a reference thermometer.
# Used at startup to derive CPU heat correction factor.
# Set to 0 if the Enviro+ is physically separated from the Pi.
CAL_ACTUAL_F=72.0

# ── MQTT (Adafruit IO) ────────────────────────────────────────────────────────
MQTT_BROKER=io.adafruit.com
MQTT_PORT=1883
MQTT_USER=your_adafruit_username
MQTT_KEY=your_adafruit_io_key
MQTT_PUBLISH_INTERVAL=60

# ── SQLite ────────────────────────────────────────────────────────────────────
SQLITE_PATH=/home/pi/projects/enviroplus/enviro.db
SQLITE_INTERVAL=60

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_PATH=/home/pi/projects/enviroplus/enviro.log

# ── InfluxDB (optional, for Grafana integration) ──────────────────────────────
# INFLUX_URL=http://100.x.x.x:8086
# INFLUX_TOKEN=your_influxdb_token
# INFLUX_ORG=home
# INFLUX_BUCKET=enviroplus
