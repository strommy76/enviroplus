[Unit]
Description=AirNow (EPA) Air Quality Poller
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pistrommy
WorkingDirectory=/home/pistrommy/projects/enviroplus
ExecStart=/home/pistrommy/.virtualenvs/pimoroni/bin/python airnow_wx.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
