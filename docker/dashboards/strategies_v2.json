      },
      "targets": [
        {
          "refId": "R_score",
          "datasource": {
            "type": "frser-sqlite-datasource",
            "uid": "stocks-sqlite-ds"
          },
          "queryType": "table",
          "rawSql": "SELECT CAST(strftime('%s', date || ' 16:00:00') AS INTEGER) AS time, SUM(value) AS \"R net (11)\" FROM vote_history WHERE strategy_set = 'R' GROUP BY date ORDER BY date",
          "timeColumns": [
            "time"
          ]
        },
        {
          "refId": "S_score",
          "datasource": {
            "type": "frser-sqlite-datasource",
            "uid": "stocks-sqlite-ds"
          },
          "queryType": "table",
          "rawSql": "SELECT CAST(strftime('%s', date || ' 16:00:00') AS INTEGER) AS time, SUM(value) AS \"S net (16)\" FROM vote_history GROUP BY date ORDER BY date",
          "timeColumns": [
            "time"
          ]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 12,
            "spanNulls": true
          },
