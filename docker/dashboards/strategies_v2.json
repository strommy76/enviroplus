    {
      "type": "table",
      "id": 13,
      "title": "Latest Vote Snapshot \u2014 every indicator, every day (last 14 trading days)",
      "description": "Rows = indicators (11 R votes + 5 S extras = 16). Columns = recent dates. Cell value: -1 (bear) / 0 (neutral) / +1 (bull). Cell-coloring thresholds: red \u2264 -1, gray = 0, green \u2265 +1. Apply 'Cell display mode = color background' on each numeric date column to render as a heatmap.",
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 37
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "stocks-sqlite-ds"
      },
      "targets": [
        {
          "refId": "votes",
          "datasource": {
            "type": "frser-sqlite-datasource",
            "uid": "stocks-sqlite-ds"
          },
          "queryType": "table",
          "rawSql": "WITH recent AS (SELECT DISTINCT date FROM vote_history ORDER BY date DESC LIMIT 14), pivoted AS (SELECT vh.vote_name AS indicator, vh.strategy_set AS scope, MAX(CASE WHEN vh.date = (SELECT date FROM recent ORDER BY date DESC LIMIT 1 OFFSET 0)  THEN vh.value END) AS \"d-0\", MAX(CASE WHEN vh.date = (SELECT date FROM recent ORDER BY date DESC LIMIT 1 OFFSET 1)  THEN vh.value END) AS \"d-1\", MAX(CASE WHEN vh.date = (SELECT date FROM recent ORDER BY date DESC LIMIT 1 OFFSET 2)  THEN vh.value END) AS \"d-2\", MAX(CASE WHEN vh.date = (SELECT date FROM recent ORDER BY date DESC LIMIT 1 OFFSET 3)  THEN vh.value END) AS \"d-3\", MAX(CASE WHEN vh.date = (SELECT date FROM recent ORDER BY date DESC LIMIT 1 OFFSET 4)  THEN vh.value END) AS \"d-4\", MAX(CASE WHEN vh.date = (SELECT date FROM recent ORDER BY date DESC LIMIT 1 OFFSET 5)  THEN vh.value END) AS \"d-5\", MAX(CASE WHEN vh.date = (SELECT date FROM recent ORDER BY date DESC LIMIT 1 OFFSET 6)  THEN vh.value END) AS \"d-6\", MAX(CASE WHEN vh.date = (SELECT date FROM recent ORDER BY date DESC LIMIT 1 OFFSET 7)  THEN vh.value END) AS \"d-7\", MAX(CASE WHEN vh.date = (SELECT date FROM recent ORDER BY date DESC LIMIT 1 OFFSET 8)  THEN vh.value END) AS \"d-8\", MAX(CASE WHEN vh.date = (SELECT date FROM recent ORDER BY date DESC LIMIT 1 OFFSET 9)  THEN vh.value END) AS \"d-9\", MAX(CASE WHEN vh.date = (SELECT date FROM recent ORDER BY date DESC LIMIT 1 OFFSET 10) THEN vh.value END) AS \"d-10\", MAX(CASE WHEN vh.date = (SELECT date FROM recent ORDER BY date DESC LIMIT 1 OFFSET 11) THEN vh.value END) AS \"d-11\", MAX(CASE WHEN vh.date = (SELECT date FROM recent ORDER BY date DESC LIMIT 1 OFFSET 12) THEN vh.value END) AS \"d-12\", MAX(CASE WHEN vh.date = (SELECT date FROM recent ORDER BY date DESC LIMIT 1 OFFSET 13) THEN vh.value END) AS \"d-13\" FROM vote_history vh WHERE vh.date IN (SELECT date FROM recent) GROUP BY vh.vote_name, vh.strategy_set) SELECT scope, indicator, \"d-0\", \"d-1\", \"d-2\", \"d-3\", \"d-4\", \"d-5\", \"d-6\", \"d-7\", \"d-8\", \"d-9\", \"d-10\", \"d-11\", \"d-12\", \"d-13\" FROM pivoted ORDER BY scope, indicator"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "center",
            "cellOptions": {
              "type": "color-background",
              "mode": "gradient"
            }
          },
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "rgb(220, 53, 69)",
                "value": null
              },
              {
                "color": "rgba(220, 53, 69, 0.5)",
                "value": -0.5
              },
              {
                "color": "rgb(60, 60, 60)",
                "value": -0.0001
              },
              {
                "color": "rgba(40, 167, 69, 0.5)",
                "value": 0.5
              },
              {
                "color": "rgb(40, 167, 69)",
                "value": 1
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "scope"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "auto"
                }
              },
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "indicator"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "auto"
                }
              },
              {
                "id": "custom.width",
                "value": 140
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "transformations": []
    },
    {
      "type": "timeseries",
      "id": 14,
      "title": "Net Vote Score (sum of bull \u2212 bear) \u2014 R 11-vote vs S 16-vote",
      "description": "At-a-glance regime tilt. Positive = bullish indicator landscape; negative = bearish.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 51
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
